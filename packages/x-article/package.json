{
  "name": "@kaitox/x-article",
  "version": "0.6.0",
  "description": "Publish Markdown as X (Twitter) Article drafts: Markdown → content_state converter, X private-API client, end-to-end publish orchestration, and an X-friendliness style checker. Works in browsers (same-origin) and Node.",
  "license": "MIT",
  "author": "kaitox <me@kaitox.ai> (https://kaitox.ai)",
  "homepage": "https://kaitox.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuangjiajia/kaitox-toolkit.git",
    "directory": "packages/x-article"
  },
  "bugs": "https://github.com/kuangjiajia/kaitox-toolkit/issues",
  "keywords": [
    "kaitox",
    "x",
    "twitter",
    "article",
    "markdown",
    "content-state",
    "draft-js",
    "publishing"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./preview.css": "./preview.css"
  },
  "files": [
    "dist",
    "src",
    "preview.css"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node test/validate.mjs && node test/preview.mjs"
  },
  "dependencies": {
    "@kaitox/relay-protocol": "^0.5.1",
    "marked": "^18.0.5"
  }
}
