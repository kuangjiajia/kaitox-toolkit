{
  "name": "@kaitox/relay",
  "version": "0.3.0",
  "description": "kaitox local relay: stores draft bundles on 127.0.0.1 — upload clients POST, browser extensions poll. Zero third-party dependencies. Ships the kaitox-relay CLI (start/dev/stop/status).",
  "license": "MIT",
  "author": "kaitox <me@kaitox.ai> (https://kaitox.ai)",
  "homepage": "https://kaitox.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaitox/kaitox.git",
    "directory": "packages/relay"
  },
  "bugs": "https://github.com/kaitox/kaitox/issues",
  "keywords": ["kaitox", "relay", "draft", "publishing", "daemon", "cli"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kaitox-relay": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js start",
    "dev": "node dist/cli.js dev",
    "stop": "node dist/cli.js stop"
  },
  "dependencies": {
    "@kaitox/relay-protocol": "^0.3.0"
  }
}
