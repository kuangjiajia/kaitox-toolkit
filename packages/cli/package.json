{
  "name": "@kaitox/cli",
  "version": "0.3.0",
  "description": "kaitox CLI — local publishing platform. Current feature: style-check, bundle and deliver local Markdown to the local relay as X (Twitter) Article drafts (kaitox x push).",
  "license": "MIT",
  "author": "kaitox <me@kaitox.ai> (https://kaitox.ai)",
  "homepage": "https://kaitox.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaitox/kaitox.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/kaitox/kaitox/issues",
  "keywords": ["kaitox", "cli", "x", "twitter", "article", "markdown", "publishing"],
  "type": "module",
  "bin": {
    "kaitox": "dist/kaitox.js"
  },
  "files": ["dist", "skills"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kaitox/relay": "^0.3.0",
    "@kaitox/relay-protocol": "^0.3.0",
    "@kaitox/x-article": "^0.3.0"
  }
}
