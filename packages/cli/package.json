{
  "name": "@kaitox/cli",
  "version": "0.4.3",
  "description": "The kaitox command line — CLI product of the Kaitox personal toolkit. Current feature: style-check, bundle and deliver local Markdown to the local relay as X (Twitter) Article drafts (kaitox x push).",
  "license": "MIT",
  "author": "kaitox <me@kaitox.ai> (https://kaitox.ai)",
  "homepage": "https://kaitox.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuangjiajia/kaitox-toolkit.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/kuangjiajia/kaitox-toolkit/issues",
  "keywords": [
    "kaitox",
    "cli",
    "x",
    "twitter",
    "article",
    "markdown",
    "publishing"
  ],
  "type": "module",
  "bin": {
    "kaitox": "dist/kaitox.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kaitox/relay": "^0.6.1",
    "@kaitox/relay-protocol": "^0.5.2",
    "@kaitox/x-article": "^0.6.1"
  }
}
