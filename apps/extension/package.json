{
  "name": "@kaitox/extension",
  "version": "0.6.1",
  "description": "Kaitox Chrome extension (MV3) — browser product of the Kaitox toolkit. Current feature: uploads pending Markdown drafts from the local relay as X (Twitter) Article drafts on x.com.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run build --prefix ../.. && node esbuild.mjs",
    "build:only": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kaitox/relay-protocol": "^0.5.2",
    "@kaitox/x-article": "^0.6.1",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
