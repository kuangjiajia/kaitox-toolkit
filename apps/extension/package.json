{
  "name": "@kaitox/extension",
  "version": "0.3.0",
  "description": "kaitox Chrome 插件（MV3）：在 x.com 文章草稿页把 relay 里的待办草稿一键上传为 X Article",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run build --prefix ../.. && node esbuild.mjs",
    "build:only": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kaitox/relay-protocol": "^0.3.0",
    "@kaitox/x-article": "^0.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268"
  }
}
