{
  "manifest_version": 3,
  "name": "Kaitox",
  "version": "0.3.0",
  "description": "Kaitox browser companion. Current feature: publish local Markdown as X (Twitter) Article drafts — syncs pending drafts from the local Kaitox relay and uploads them on the drafts page.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "*://x.com/*",
    "*://upload.x.com/*",
    "*://twitter.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/compose/articles*",
        "https://twitter.com/compose/articles*"
      ],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Kaitox"
  }
}
