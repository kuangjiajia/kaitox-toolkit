{
  "manifest_version": 3,
  "name": "Kaitox",
  "version": "0.5.0",
  "description": "Kaitox toolkit browser companion. Uploads pending Markdown drafts from the local Kaitox relay as X (Twitter) Article drafts.",
  "permissions": ["storage", "alarms", "activeTab", "scripting"],
  "host_permissions": [
    "*://x.com/*",
    "*://upload.x.com/*",
    "*://twitter.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "css": ["panel.css", "preview.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["mermaid-lib.js"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Kaitox",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": false
  }
}
